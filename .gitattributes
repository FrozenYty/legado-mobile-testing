# Auto-detect text files and normalize line endings to LF on commit
*       text=auto

# Source code — always LF
*.kt    text eol=lf
*.java  text eol=lf
*.xml   text eol=lf
*.kts   text eol=lf
*.gradle text eol=lf

# Scripts — always LF
*.sh    text eol=lf

# Documentation — LF preferred
*.md    text eol=lf
*.yml   text eol=lf

# Binaries — don't touch
*.png   binary
*.jpg   binary
*.apk   binary
*.aab   binary
*.jks   binary
*.keystore binary
